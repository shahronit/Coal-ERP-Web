{
  "name": "coal-trading-erp-backend",
  "version": "1.0.0",
  "description": "VK Trading ERP API Server",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:web": "TRADECRM_STATIC_DIR=../frontend/dist node src/server.js",
    "dev": "nodemon src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "dev:seed": "node scripts/dev-seed.js",
    "demo:seed": "node scripts/demo-seed.js",
    "migrate:sqlite-to-postgres": "node scripts/migrate-sqlite-to-postgres.js",
    "migrate:postgres-to-firestore": "node scripts/migrate-postgres-to-firestore.js",
    "setup:firebase": "node scripts/setup-firebase.js",
    "db:audit": "node scripts/db-audit.js",
    "test:firestore-live": "node scripts/test-firestore-live.js",
    "validate:parity": "node scripts/validate-parity.js",
    "test": "node --test tests/integration/full-app.test.js",
    "test:full": "node --test tests/integration/full-app.test.js",
    "test:integration": "node --test tests/integration/firestore.test.js",
    "test:all": "node --test tests/integration/*.test.js",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@google-cloud/firestore": "^7.11.0",
    "@prisma/client": "^5.22.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "extract-zip": "^2.0.1",
    "firebase-admin": "^12.7.0",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.16.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.5",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prisma": "^5.22.0"
  }
}
