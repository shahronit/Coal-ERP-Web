# Web application — PostgreSQL (recommended for self-hosted)
DATABASE_URL=postgresql://tradecrm:tradecrm@127.0.0.1:5432/tradecrm
DATABASE_PROVIDER=postgres

# Bind on all interfaces so LAN/Tailscale clients can reach the API
HOST=0.0.0.0
PORT=4000
NODE_ENV=development

# Strong secrets (generate with: openssl rand -hex 48)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars

# CORS — add your deployment URLs (comma-separated)
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4000

# Serve built React app from Express (production / npm run start:web)
TRADECRM_STATIC_DIR=../frontend/dist

# File uploads
UPLOAD_DIR=./uploads

# Optional: Firestore cloud mode (see docs/FIREBASE.md in desktop repo)
# DATABASE_PROVIDER=firestore
# FIREBASE_PROJECT_ID=your-project-id
