# Firebase / Firestore — coal-trading-app
DATABASE_PROVIDER=firestore

# From Firebase Console → Project settings → General
FIREBASE_PROJECT_ID=coal-trading-app
FIREBASE_STORAGE_BUCKET=coal-trading-app.firebasestorage.app

# Local emulator (optional — Spark dev without Blaze)
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# Backend Admin SDK — download from Firebase Console → Service accounts → Generate new private key
# NEVER commit this file. Save as backend/serviceAccountKey.json (gitignored)
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Rollback to local Postgres
# DATABASE_PROVIDER=postgres
# DATABASE_URL=postgresql://tradecrm:tradecrm@127.0.0.1:5432/tradecrm

HOST=0.0.0.0
PORT=8080
NODE_ENV=production

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# App URLs (Hosting)
FRONTEND_URL=https://coal-trading-app.web.app
CORS_ALLOWED_ORIGINS=https://coal-trading-app.web.app,https://coal-trading-app.firebaseapp.com

# GCS bucket for Firestore exports + backup zips (create in GCP Console)
BACKUP_GCS_BUCKET=coal-trading-app-backups
